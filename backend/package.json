{
  "name": "@dentai/backend",
  "version": "1.0.0",
  "private": true,
  "type": "commonjs",
  "main": "server.js",
  "scripts": {
    "start": "node server.js",
    "dev": "node server.js",
    "server": "node server.js",
    "db:push": "prisma db push --schema=../prisma/schema.prisma",
    "db:studio": "prisma studio --schema=../prisma/schema.prisma",
    "db:seed": "node ../prisma/seed.js",
    "ai:verify": "node scripts/ai-verification.js",
    "test:classifier": "node lib/ai/__tests__/query-classifier.test.js",
    "test:finance-semantics": "node lib/ai/__tests__/finance-semantics.test.js",
    "test:interpretation": "node lib/ai/__tests__/query-interpretation.test.js",
    "test:pipeline-scope": "node lib/ai/__tests__/pipeline-scope.test.js",
    "test:planner-architecture": "node lib/ai/__tests__/planner-architecture.test.js",
    "test:ai": "node lib/ai/__tests__/query-classifier.test.js && node lib/ai/__tests__/query-interpretation.test.js && node lib/ai/__tests__/pipeline-scope.test.js && node lib/ai/__tests__/planner-architecture.test.js && node lib/ai/__tests__/finance-semantics.test.js"
  },
  "dependencies": {
    "@prisma/client": "^6.1.0",
    "bcryptjs": "^2.4.3",
    "bullmq": "^5.29.2",
    "cors": "^2.8.5",
    "express": "^4.18.2",
    "express-session": "^1.17.3",
    "ioredis": "^5.4.2",
    "multer": "^2.1.1",
    "zod": "^3.24.1"
  },
  "devDependencies": {
    "prisma": "^6.1.0"
  }
}
