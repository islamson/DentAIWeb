# Copy to .env and adjust. Live AI chat now uses:
# 1) LLM planner
# 2) backend validation / retrieval
# 3) LLM answer synthesis
#
# Ollama unavailable => chat returns explicit 503 instead of shallow fallback answers.
# AI_MODE remains only for legacy/verification scripts.
AI_MODE=llm

# Ollama connection (default: http://127.0.0.1:11434)
OLLAMA_BASE_URL=http://127.0.0.1:11434

# Model name - passed as-is to Ollama (e.g. llama3.1:8b-instruct-q4_K_M)
OLLAMA_MODEL="deepseek-r1:14b"

# Timeout for Ollama API calls (ms)
OLLAMA_TIMEOUT_MS=60000

# Final answer synthesis also uses the local LLM.
# Keep this true in the new planner-first architecture.
USE_LLM_FORMATTING=true
